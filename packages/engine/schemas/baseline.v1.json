{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repofit.dev/schema/baseline.v1.json",
  "title": "repofit baseline",
  "description": "Schema for repofit-baseline.json (version 1). Snapshot of accepted scores used by gate.mode=ratchet.",
  "type": "object",
  "required": ["version", "acceptedAt", "corpus", "fitness", "dimensions", "probes"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "integer", "const": 1 },
    "acceptedAt": {
      "type": "string",
      "description": "ISO 8601 timestamp when the baseline was accepted."
    },
    "acceptedBy": { "type": "string" },
    "commit": {
      "type": "string",
      "description": "Git SHA at the time of acceptance."
    },
    "corpus": {
      "type": "array",
      "description": "Corpus packages and versions at acceptance time.",
      "items": {
        "type": "object",
        "required": ["package", "version"],
        "additionalProperties": false,
        "properties": {
          "package": { "type": "string", "minLength": 1 },
          "version": { "type": "string", "minLength": 1 }
        }
      }
    },
    "fitness": {
      "type": ["number", "null"],
      "description": "Overall fitness score (0-100), or null if not computed."
    },
    "dimensions": {
      "type": "object",
      "description": "Dimension id → score (0-100) or null.",
      "additionalProperties": { "type": ["number", "null"] }
    },
    "probes": {
      "type": "object",
      "description": "Probe id → score (0-100) or null.",
      "additionalProperties": { "type": ["number", "null"] }
    }
  }
}
