{
  "name": "agentry",
  "version": "0.0.0",
  "description": "Form your agentic readiness — audit, install, and coach any repo toward better agentic coding.",
  "type": "module",
  "bin": {
    "agentry": "./dist/index.js"
  },
  "files": [
    "dist/",
    "content/",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo 'lint placeholder — wire eslint when src grows'",
    "test": "echo 'test placeholder — wire vitest when src grows'"
  },
  "keywords": [
    "agent",
    "agentic",
    "claude",
    "cli",
    "harness",
    "codex",
    "developer-tools"
  ],
  "author": "Esben Wiberg",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/esbenwiberg/agentry.git"
  },
  "bugs": {
    "url": "https://github.com/esbenwiberg/agentry/issues"
  },
  "homepage": "https://github.com/esbenwiberg/agentry#readme",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
