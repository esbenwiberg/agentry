#!/bin/sh
# commit-msg hook — validates conventional commit format.

COMMIT_MSG_FILE=$1
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

PATTERN="^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|merge|revert|breaking|security)(\(.+\))?: .{1,100}"

if ! echo "$COMMIT_MSG" | grep -qE "$PATTERN"; then
    printf "${RED}ERROR: commit message does not follow conventional commit format${NC}\n"
    printf "\n"
    printf "Expected: ${GREEN}type(scope): subject${NC}\n"
    printf "\n"
    printf "Valid types: feat, fix, docs, style, refactor, perf, test, build,\n"
    printf "             ci, chore, merge, revert, breaking, security\n"
    printf "\n"
    printf "Examples:\n"
    printf "  ${GREEN}feat(engine): add config loader${NC}\n"
    printf "  ${GREEN}fix(corpus): handle missing CLAUDE.md gracefully${NC}\n"
    printf "  ${GREEN}docs: update README quickstart${NC}\n"
    printf "\n"
    exit 1
fi

printf "${GREEN}commit message OK${NC}\n"
exit 0
