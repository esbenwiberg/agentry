#!/usr/bin/env bash
# pre-commit hook — runs cheap checks before commit.
# Bypass: git commit --no-verify (don't — fix the underlying issue instead).

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SECRET_CHECKS="$SCRIPT_DIR/lib/secret-checks.sh"
BUILD_CHECKS="$SCRIPT_DIR/lib/build-checks.sh"

if ! git rev-parse --git-dir > /dev/null 2>&1; then
    echo -e "${RED}Not in a git repository${NC}"
    exit 1
fi

if git diff --cached --quiet; then
    echo -e "${YELLOW}No staged files — nothing to check${NC}"
    exit 0
fi

echo -e "${CYAN}── repofit pre-commit ──${NC}"

OVERALL=0

if [ -f "$SECRET_CHECKS" ]; then
    if ! bash "$SECRET_CHECKS"; then
        OVERALL=1
    fi
fi

if [ -f "$BUILD_CHECKS" ]; then
    if ! bash "$BUILD_CHECKS"; then
        OVERALL=1
    fi
fi

if [ $OVERALL -eq 0 ]; then
    echo -e "${GREEN}pre-commit OK${NC}"
else
    echo -e "${RED}pre-commit failed${NC}"
    echo -e "${YELLOW}Fix the issue above. Avoid --no-verify.${NC}"
fi

exit $OVERALL
