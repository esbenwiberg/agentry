#!/bin/sh
# commit-msg hook — validates conventional commit format and enforces
# changelog fragments for non-trivial change types.

COMMIT_MSG_FILE=$1
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

PATTERN="^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|merge|revert|breaking|security)(\(.+\))?: .{1,100}"

if ! echo "$COMMIT_MSG" | grep -qE "$PATTERN"; then
    printf "${RED}ERROR: commit message does not follow conventional commit format${NC}\n"
    printf "\n"
    printf "Expected: ${GREEN}type(scope): subject${NC}\n"
    printf "\n"
    printf "Valid types: feat, fix, docs, style, refactor, perf, test, build,\n"
    printf "             ci, chore, merge, revert, breaking, security\n"
    printf "\n"
    printf "Examples:\n"
    printf "  ${GREEN}feat(cli): add doctor verb${NC}\n"
    printf "  ${GREEN}fix(hooks): handle missing gitleaks gracefully${NC}\n"
    printf "  ${GREEN}docs: update README posture section${NC}\n"
    printf "\n"
    exit 1
fi

COMMIT_TYPE=$(echo "$COMMIT_MSG" | head -1 | sed -E 's/^([a-z]+)(\(.+\))?: .*/\1/')

# Skip fragment requirement for these types
SKIP_CHANGELOG_TYPES="docs|style|test|ci|merge|chore|revert"

if ! echo "$COMMIT_TYPE" | grep -qE "^($SKIP_CHANGELOG_TYPES)$"; then
    FRAGMENT_COUNT=$(git diff --cached --name-only | grep -cE "^\.changes/.*\.(feat|fix|breaking|perf|security|refactor|build)\.md$" || true)

    if [ "$FRAGMENT_COUNT" -eq 0 ]; then
        printf "${YELLOW}WARNING: no changelog fragment found${NC}\n"
        printf "\n"
        printf "Type '${COMMIT_TYPE}' requires a fragment in .changes/.\n"
        printf "\n"
        printf "${GREEN}Create one:${NC}\n"
        printf "  _scripts/changelog/create-fragment.sh \\\\\n"
        printf "    -t ${COMMIT_TYPE} \\\\\n"
        printf "    -s <scope> \\\\\n"
        printf "    -n <descriptive-name> \\\\\n"
        printf "    -d \"<description>\"\n"
        printf "\n"
        printf "Then ${GREEN}git add .changes/<file>${NC} and re-commit.\n"
        printf "\n"
        printf "Spec: .changes/README.md\n"
        printf "\n"
        exit 1
    fi
fi

if echo "$COMMIT_MSG" | grep -q "BREAKING CHANGE:"; then
    printf "${YELLOW}BREAKING CHANGE detected — ensure a .breaking.md fragment is staged.${NC}\n"
fi

printf "${GREEN}commit message OK${NC}\n"
exit 0
