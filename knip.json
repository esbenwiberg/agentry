{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreBinaries": ["repofit"],
  "ignoreExportsUsedInFile": true,
  "workspaces": {
    "packages/engine": {
      "entry": ["test/**/*.test.ts"],
      "project": ["src/**/*.ts", "test/**/*.ts"]
    },
    "packages/corpus-default": {
      "entry": ["test/**/*.test.ts"],
      "project": ["src/**/*.ts", "test/**/*.ts"]
    }
  }
}
